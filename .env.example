DATA_MODE=multi_provider
LLM_PROVIDER=groq
ROUTER_MODE=semantic
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=your_key_here
SEMANTIC_COLLECTION_NAME=approved_routing_examples_v3
SEMANTIC_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
SEMANTIC_SCORE_THRESHOLD=0.72
SEMANTIC_MARGIN_THRESHOLD=0.05
SEMANTIC_TOP_K=5
RESPONSE_MODE=llm
GROQ_API_KEY=your_key_here
LLM_MODEL=llama-3.1-8b-instant
LLM_MAX_TOKENS=600
MAX_LLM_CALLS_PER_QUERY=2
PROMPT_GUARD_ENABLED=true
PROMPT_GUARD_MODEL=./models/threat-analyst-prompt-guard
PROMPT_GUARD_MAX_TOKENS=64
PROMPT_GUARD_THRESHOLD=0.957909
RETRIEVED_SEMANTIC_GUARD_ENABLED=true
RETRIEVED_GUARD_MAX_CHARS=4000
# Only required to download the gated base model for retraining; local inference needs no token.
HUGGINGFACE_TOKEN=
MAX_TOOL_CALLS_PER_QUERY=3
API_TIMEOUT_SECONDS=10
API_CONNECT_TIMEOUT_SECONDS=3
API_WRITE_TIMEOUT_SECONDS=5
API_POOL_TIMEOUT_SECONDS=3
PROVIDER_CACHE_TTL_SECONDS=300
PROVIDER_CACHE_MAX_ENTRIES=256
PROVIDER_MAX_WORKERS=3

VIRUSTOTAL_API_KEY=your_key_here
ALIEN_VAULT_API_KEY=your_key_here
NVD_API_KEY=your_key_here
ABUSEIPDB_API_KEY=your_key_here
